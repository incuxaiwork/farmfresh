# System Port Configuration
PORT=3000

# Database Connections
DATABASE_URL="postgresql://postgres:password123@localhost:5432/farmfresh?schema=public"

# Security & Tokens Keys
JWT_SECRET="generate-a-secure-random-access-secret-key-phrase"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_SECRET="generate-a-secure-random-refresh-secret-key-phrase"
JWT_REFRESH_EXPIRATION="7d"

# Rate Limit
THROTTLE_TTL=60
THROTTLE_LIMIT=100
